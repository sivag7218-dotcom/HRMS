              "host": ["{{base_url}}"],
              "path": ["api", "payroll-master", "components"],
              "query": [
                {
                  "key": "structure_id",
                  "value": "{{structure_id}}"
                }
              ]
            }
          }
        },
        {
          "name": "Create Component",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"structure_id\": 1,\n  \"code\": \"BONUS\",\n  \"name\": \"Annual Bonus\",\n  \"component_type\": \"EARNING\",\n  \"calculation_type\": \"PERCENTAGE\",\n  \"value\": 10.00,\n  \"taxable\": true,\n  \"prorated\": false,\n  \"sequence\": 100\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/payroll-master/components",
              "host": ["{{base_url}}"],
              "path": ["api", "payroll-master", "components"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Payroll Processing",
      "item": [
        {
          "name": "Run Payroll for February 2026",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"year\": 2026,\n  \"month\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/payroll/v2/run",
              "host": ["{{base_url}}"],
              "path": ["api", "payroll", "v2", "run"]
            }
          }
        },
        {
          "name": "Get Monthly Run Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/payroll/v2/run?month=2026-02",
              "host": ["{{base_url}}"],
              "path": ["api", "payroll", "v2", "run"],
              "query": [
                {
                  "key": "month",
                  "value": "2026-02"
                }
              ]
            }
          }
        }
      ]
    },
    {
