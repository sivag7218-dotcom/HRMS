# HRMS Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# CRITICAL: JWT Configuration (REQUIRED)
# ============================================
# Generate a secure secret with this command:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Never use the default value in production!
JWT_SECRET=your-secure-random-secret-here-min-32-chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ============================================
# Database Configuration
# ============================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=hrms_db_new
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
DB_CONNECT_TIMEOUT=10000
DB_ACQUIRE_TIMEOUT=10000
DB_QUERY_TIMEOUT=30000

# ============================================
# Security Configuration
# ============================================
# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true
BCRYPT_ROUNDS=10

# Authentication Protection
MAX_LOGIN_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# ============================================
# File Upload Configuration
# ============================================
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx

# ============================================
# Email Configuration (Optional)
# ============================================
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@hrms.local

# ============================================
# Pagination Defaults
# ============================================
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=1000

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log
